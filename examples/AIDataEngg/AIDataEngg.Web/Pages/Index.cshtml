@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <h2>Dashboard</h2>
    <p class="text-muted">Overview of recent signal intelligence activity</p>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-value" id="stat-signals">@Model.SignalCount</div>
        <div class="stat-label">Signals</div>
    </div>
    <div class="stat-card stat-noise">
        <div class="stat-value" id="stat-noise">@Model.NoiseCount</div>
        <div class="stat-label">Noise</div>
    </div>
    <div class="stat-card stat-bounced">
        <div class="stat-value" id="stat-bounced">@Model.BouncedCount</div>
        <div class="stat-label">Bounced</div>
    </div>
    <div class="stat-card">
        <div class="stat-value">@Model.TotalFeeds</div>
        <div class="stat-label">Feeds</div>
    </div>
</div>

<!-- Workflow chart -->
<div class="workflow hidden" id="workflow">
    <div class="stage-card">
        <div class="stage-count" id="wf-feeds">0</div>
        <div class="stage-label">Feeds</div>
    </div>
    <div class="stage-arrow">&#10132;</div>
    <div class="stage-card">
        <div class="stage-count" id="wf-items">0</div>
        <div class="stage-label">Items</div>
    </div>
    <div class="stage-arrow">&#10132;</div>
    <div class="stage-card stage-card-progress">
        <div class="stage-count" id="wf-classified">0 / 0</div>
        <div class="stage-label">Classified</div>
        <div class="stage-progress"><div class="stage-progress-fill" id="wf-progress-fill"></div></div>
    </div>
    <div class="stage-arrow">&#10132;</div>
    <div class="stage-card stage-card-signals">
        <div class="stage-count" id="wf-signals">0</div>
        <div class="stage-label">Signals</div>
    </div>
    <div class="stage-card stage-card-noise">
        <div class="stage-count" id="wf-noise">0</div>
        <div class="stage-label">Noise</div>
    </div>
    <div class="stage-card stage-card-failed">
        <div class="stage-count" id="wf-failed">0</div>
        <div class="stage-label">Failed</div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3>Recent Classifications</h3>
        <span class="text-muted" id="recent-updated"></span>
    </div>
    <div class="card-body" id="recent-items">
        @if (Model.RecentItems.Count == 0)
        {
            <p class="text-muted">No classifications yet. Click <strong>Process</strong> to start.</p>
        }
        else
        {
            <div class="item-list">
                @foreach (var item in Model.RecentItems)
                {
                    var dashBadge = item.IsNoise ? "NOISE" : item.Signal;
                    var dashBadgeClass = item.IsNoise ? "signal-noise" : "";
                    @await Html.PartialAsync("Shared/_ItemRow", item, new ViewDataDictionary(ViewData)
                    {
                        ["Badge"] = dashBadge,
                        ["BadgeClass"] = dashBadgeClass
                    })
                }
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-header" onclick="toggleLog(this)" style="cursor:pointer;user-select:none;">
        <h3>Pipeline Details</h3>
        <span class="log-toggle">&#9660;</span>
    </div>
    <div class="card-body log-body" id="pipeline-log">
        <p class="text-muted">No activity yet.</p>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var logCard = document.querySelector('.card:last-child');
            if (window.location.hash === '#log') {
                logCard.classList.remove('log-collapsed');
            }
        });

        function toggleLog(header) {
            var card = header.parentElement;
            card.classList.toggle('log-collapsed');
        }
    </script>
}
