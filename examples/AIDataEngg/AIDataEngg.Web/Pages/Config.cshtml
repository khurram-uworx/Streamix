@page
@model ConfigModel
@{
    ViewData["Title"] = "Configuration";
}

<div class="page-header">
    <h2>Configuration</h2>
    <p class="text-muted">Edit feeds, signals, goal, and classification prompt — saved as markdown files</p>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert @(Model.IsError ? "alert-error" : "alert-success")">
        @Model.Message
    </div>
}

<form method="post" class="config-form">
    <div class="config-section">
        <div class="config-section-header">
            <h3>Feed Sources</h3>
            <span class="text-muted">One per line: <code>Name | URL</code></span>
        </div>
        <textarea asp-for="FeedSourcesText" class="config-textarea" rows="6" spellcheck="false"></textarea>
    </div>

    <div class="config-section">
        <div class="config-section-header">
            <h3>Business Goal</h3>
            <span class="text-muted">Describes what signals are relevant to your organization</span>
        </div>
        <textarea asp-for="GoalText" class="config-textarea" rows="8"></textarea>
    </div>

    <div class="config-section">
        <div class="config-section-header">
            <h3>Signals</h3>
            <span class="text-muted">One signal name per line</span>
        </div>
        <textarea asp-for="SignalsText" class="config-textarea" rows="7" spellcheck="false"></textarea>
    </div>

    <div class="config-section">
        <div class="config-section-header">
            <h3>Classification Prompt</h3>
            <span class="text-muted">Template with <code>{goalText}</code> and <code>{signalsText}</code> placeholders</span>
        </div>
        <textarea asp-for="PromptText" class="config-textarea config-textarea-prompt" rows="12"></textarea>
    </div>

    <div class="config-actions">
        <button type="submit" class="btn-save">Save Configuration</button>
    </div>
</form>
