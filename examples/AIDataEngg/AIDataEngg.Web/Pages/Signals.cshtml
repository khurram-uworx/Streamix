@page
@model SignalsModel
@{
    ViewData["Title"] = Model.CurrentSignal ?? "Signals";
}

<div class="page-header">
    @if (!string.IsNullOrEmpty(Model.CurrentSignal))
    {
        <div class="detail-header">
            <a href="/Signals" class="btn-back">&larr; All Signals</a>
            <h2>@Model.CurrentSignal</h2>
        </div>
        <p class="text-muted">@Model.TotalCount classified item(s)</p>
    }
    else
    {
        <h2>Signals <span class="text-muted">(inbox)</span></h2>
        <p class="text-muted">Classified signal items grouped by category</p>
    }
</div>

@if (Model.Groups.Count == 0)
{
    @await Html.PartialAsync("Shared/_EmptyState", new ViewDataDictionary(ViewData)
    {
        ["Message"] = Model.CurrentSignal is not null ? "No items in this category." : "No signals yet. Run the pipeline to classify items."
    })
}
else if (!string.IsNullOrEmpty(Model.CurrentSignal))
{
    <div class="item-list">
        @foreach (var item in Model.Groups[0].Items)
        {
            @await Html.PartialAsync("Shared/_ItemRow", item, new ViewDataDictionary(ViewData)
            {
                ["Actions"] = true,
                ["ActionStyle"] = "warning",
                ["SignalName"] = Model.CurrentSignal,
                ["Reasoning"] = true
            })
        }
    </div>
}
else
{
    <div class="signal-groups">
        @foreach (var group in Model.Groups)
        {
            <div class="signal-group">
                <div class="signal-group-header" onclick="toggleGroup(this)">
                    <span class="signal-group-name">@group.Signal</span>
                    <span class="signal-group-count">@group.Count items</span>
                    <span class="signal-toggle">&#9660;</span>
                </div>
                <div class="signal-group-body">
                    @foreach (var item in group.Items)
                    {
                        @await Html.PartialAsync("Shared/_ItemRow", item, new ViewDataDictionary(ViewData)
                        {
                            ["Actions"] = true,
                            ["ActionStyle"] = "warning",
                            ["SignalName"] = group.Signal,
                            ["Reasoning"] = true
                        })
                    }
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        function toggleGroup(header) {
            header.parentElement.classList.toggle('collapsed');
        }
    </script>
}
