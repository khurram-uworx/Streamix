@page
@model NoiseModel
@{
    ViewData["Title"] = "Noise";
}

<div class="page-header">
    <h2>Noise <span class="text-muted">(spam)</span></h2>
    <p class="text-muted">Items classified as irrelevant noise</p>
</div>

@if (Model.Items.Count == 0)
{
    @await Html.PartialAsync("Shared/_EmptyState", new ViewDataDictionary(ViewData)
    {
        ["Message"] = "No noise items yet."
    })
}
else
{
    <div class="item-list">
        @foreach (var item in Model.Items)
        {
            @await Html.PartialAsync("Shared/_ItemRow", item, new ViewDataDictionary(ViewData)
            {
                ["Badge"] = "NOISE",
                ["BadgeClass"] = "signal-noise",
                ["RowClass"] = "item-noise",
                ["Actions"] = true,
                ["Reasoning"] = true
            })
        }
    </div>
}

@section Scripts {
    <script>
        // Noise-specific JS
    </script>
}
