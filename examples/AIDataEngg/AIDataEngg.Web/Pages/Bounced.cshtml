@page
@model BouncedModel
@{
    ViewData["Title"] = "Bounced";
}

<div class="page-header">
    <h2>Bounced <span class="text-muted">(failed classifications)</span></h2>
    <p class="text-muted">Items that exceeded retry limits and could not be classified</p>
</div>

@if (Model.Items.Count == 0)
{
    @await Html.PartialAsync("Shared/_EmptyState", new ViewDataDictionary(ViewData)
    {
        ["Message"] = "No bounced items."
    })
}
else
{
    <div class="item-list">
        @foreach (var item in Model.Items)
        {
            @await Html.PartialAsync("Shared/_ItemRow", item, new ViewDataDictionary(ViewData)
            {
                ["Badge"] = "BOUNCED",
                ["BadgeClass"] = "signal-bounced",
                ["RowClass"] = "item-bounced",
                ["Actions"] = true
            })
        }
    </div>
}

@section Scripts {
    <script>
        // Bounced-specific JS
    </script>
}
